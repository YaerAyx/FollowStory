<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F2F7">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="24dp"
        android:paddingBottom="24dp">

        <!-- Theme Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="THEME"
            android:textSize="13sp"
            android:textColor="#8E8E93"
            android:layout_marginBottom="8dp"
            android:layout_marginStart="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_ios_group">

            <!-- Light Theme Row -->
            <LinearLayout
                android:id="@+id/row_light_theme"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:clickable="true"
                android:background="?attr/selectableItemBackground"
                android:padding="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="浅色 (Light Pastel)"
                    android:textSize="17sp"
                    android:textColor="#000000"/>

                <ImageView
                    android:id="@+id/img_check_light"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_check_blue"
                    android:visibility="visible"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E5E5EA" android:layout_marginStart="16dp"/>

            <!-- Dark Theme Row -->
            <LinearLayout
                android:id="@+id/row_dark_theme"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:clickable="true"
                android:background="?attr/selectableItemBackground"
                android:padding="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="深色 (Deep Space)"
                    android:textSize="17sp"
                    android:textColor="#000000"/>

                <ImageView
                    android:id="@+id/img_check_dark"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_check_blue"
                    android:visibility="invisible"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Customization Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CUSTOMIZATION"
            android:textSize="13sp"
            android:textColor="#8E8E93"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="8dp"
            android:layout_marginStart="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_ios_group">

            <!-- Custom BG -->
            <LinearLayout
                android:id="@+id/btn_custom_bg"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:clickable="true"
                android:background="?attr/selectableItemBackground"
                android:padding="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="自定义背景图片"
                    android:textColor="#000000"
                    android:textSize="17sp" />

                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_chevron_right" android:alpha="0.3"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E5E5EA" android:layout_marginStart="16dp"/>

            <!-- Reset BG -->
            <LinearLayout
                android:id="@+id/btn_reset_bg"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:clickable="true"
                android:background="?attr/selectableItemBackground"
                android:padding="16dp">
                <TextView
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:text="重置背景为默认" android:textSize="17sp" android:textColor="#007AFF"/>
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_chevron_right" android:alpha="0.3"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E5E5EA" android:layout_marginStart="16dp"/>

            <!-- Blur adjustment -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:id="@+id/tv_blur_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="背景模糊度"
                    android:textColor="#333333"
                    android:textSize="17sp" />
                <SeekBar
                    android:id="@+id/sb_blur"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:max="25"
                    android:progress="0" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E5E5EA" android:layout_marginStart="16dp"/>

            <!-- Course Color -->
            <LinearLayout
                android:id="@+id/btn_course_color"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:clickable="true"
                android:background="?attr/selectableItemBackground"
                android:padding="16dp">
                <TextView
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:text="课程颜色配置" android:textSize="17sp" android:textColor="#000000"/>
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_chevron_right" android:alpha="0.3"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E5E5EA" android:layout_marginStart="16dp"/>

            <!-- Term Start Date -->
            <LinearLayout
                android:id="@+id/btn_term_start"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:clickable="true"
                android:background="?attr/selectableItemBackground"
                android:padding="16dp">
                <TextView
                    android:id="@+id/tv_term_start_value"
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:text="开学日期设置" android:textSize="17sp" android:textColor="#000000"/>
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_chevron_right" android:alpha="0.3"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E5E5EA" android:layout_marginStart="16dp"/>

            <!-- Reminder -->
            <LinearLayout
                android:id="@+id/btn_reminder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:clickable="true"
                android:background="?attr/selectableItemBackground"
                android:padding="16dp">
                <TextView
                    android:id="@+id/tv_reminder_value"
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:text="提醒时间设置" android:textSize="17sp" android:textColor="#000000"/>
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_chevron_right" android:alpha="0.3"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E5E5EA" android:layout_marginStart="16dp"/>

            <!-- Clear Data -->
            <LinearLayout
                android:id="@+id/btn_clear_data"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:clickable="true"
                android:background="?attr/selectableItemBackground"
                android:padding="16dp">
                <TextView
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:text="清除所有课程数据" android:textSize="17sp" android:textColor="#FF3B30"/>
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_chevron_right" android:alpha="0.3"/>
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
